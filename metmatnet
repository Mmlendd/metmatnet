<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>infra playbook · routing / dns / containers</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #f7f9fc;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            color: #1a2c3e;
            padding: 2rem 1.5rem;
            line-height: 1.5;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
        }

        /* header — как личный блог */
        .blog-header {
            text-align: center;
            margin-bottom: 2.5rem;
            border-bottom: 1px solid #dce5f0;
            padding-bottom: 1.8rem;
        }

        .blog-header h1 {
            font-size: 2.4rem;
            font-weight: 600;
            background: linear-gradient(135deg, #1f5e8c, #2d8f6e);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: -0.5px;
        }

        .blog-header p {
            color: #4a627a;
            max-width: 600px;
            margin: 0.6rem auto 0;
            font-size: 0.95rem;
        }

        .meta-line {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            margin-top: 1rem;
            font-size: 0.75rem;
            color: #6a7f9b;
            flex-wrap: wrap;
        }

        /* intro блок — теория/мысли */
        .theory-card {
            background: #eef3fa;
            border-left: 5px solid #2c8c6b;
            padding: 1.4rem 2rem;
            border-radius: 24px;
            margin: 1.8rem 0;
            color: #1f3a4b;
            font-size: 0.95rem;
            box-shadow: 0 2px 6px rgba(0,0,0,0.02);
        }

        .theory-card h3 {
            font-weight: 500;
            margin-bottom: 0.5rem;
            color: #1f5e8c;
        }

        /* поиск */
        .search-wrap {
            margin: 1rem 0 1.2rem;
        }
        #searchInput {
            width: 100%;
            padding: 0.8rem 1.2rem;
            border-radius: 48px;
            border: 1px solid #cbdae9;
            background: white;
            font-size: 0.9rem;
            font-family: monospace;
            outline: none;
            transition: 0.2s;
        }
        #searchInput:focus {
            border-color: #3b9e7c;
            box-shadow: 0 0 0 3px rgba(59,158,124,0.1);
        }

        /* фильтры — неочевидные названия */
        .topic-filters {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin: 1rem 0 2rem;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 0.8rem;
        }
        .topic-btn {
            background: transparent;
            border: none;
            padding: 0.4rem 1rem;
            border-radius: 40px;
            font-weight: 500;
            font-size: 0.8rem;
            cursor: pointer;
            color: #4a627a;
            transition: 0.1s;
        }
        .topic-btn.active {
            background: #1f5e8c;
            color: white;
        }

        /* сетка карточек */
        .entries-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
            gap: 1.6rem;
            margin-top: 1rem;
        }

        .entry {
            background: white;
            border-radius: 28px;
            padding: 1.3rem;
            box-shadow: 0 5px 14px rgba(0,0,0,0.03);
            border: 1px solid #e2edf7;
            transition: all 0.2s;
        }
        .entry:hover {
            border-color: #b9d4e8;
            transform: translateY(-2px);
            box-shadow: 0 12px 22px rgba(0,0,0,0.05);
        }

        .entry-badge {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #5e7e9e;
            margin-bottom: 0.6rem;
        }

        .entry-title {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 0.6rem;
            color: #173e54;
        }

        .code-snip {
            background: #0f172a;
            color: #e2e8f0;
            font-family: 'Fira Code', monospace;
            font-size: 0.75rem;
            padding: 0.7rem;
            border-radius: 16px;
            margin: 0.8rem 0;
            overflow-x: auto;
            white-space: pre-wrap;
            word-break: break-word;
        }

        .desc-text {
            color: #2c4c6e;
            font-size: 0.85rem;
            margin: 0.5rem 0;
        }

        .example-block {
            background: #f2f6fb;
            padding: 0.6rem;
            border-radius: 14px;
            font-size: 0.75rem;
            font-family: monospace;
            color: #285e7a;
            margin-top: 0.8rem;
        }

        hr {
            margin: 2rem 0;
            border: none;
            border-top: 1px solid #dce5f0;
        }

        footer {
            text-align: center;
            margin-top: 4rem;
            font-size: 0.7rem;
            color: #809ab3;
            border-top: 1px solid #dfe8f2;
            padding-top: 2rem;
        }
    </style>
</head>
<body>
<div class="container">
    <div class="blog-header">
        <h1>~/notes.on.infra</h1>
        <p>заметки про маршрутизацию, DNS, контейнеры и автоматизацию<br>личный опыт, примеры и рабочие конфиги</p>
        <div class="meta-line">
            <span>🗂️ последние изменения: март 2026</span>
            <span>🐧 debian / eltex / docker</span>
            <span>📌 40+ примеров</span>
        </div>
    </div>

    <!-- теория 1: философия -->
    <div class="theory-card">
        <h3>📘 О подходе к сетевым конфигурациям</h3>
        <p>При построении связанной инфраструктуры важно разделять логику маршрутизации, трансляцию адресов и сервисные зоны. Ниже — набор рецептов, которые я использую для быстрого развёртывания небольших офисных сетей с GRE-туннелями, OSPF и изолированными LAN. Везде, где возможно, предпочитаю сохранять читаемость конфигов и версионировать их.</p>
    </div>

    <div class="search-wrap">
        <input type="text" id="searchInput" placeholder="🔍 поиск по командам, адресам, именам хостов (например, gre, ospf, bind, 10.10.10)">
    </div>

    <div class="topic-filters" id="filterGroup">
        <button class="topic-btn active" data-area="all">📋 все заметки</button>
        <button class="topic-btn" data-area="sysbase">⚙️ sys/base</button>
        <button class="topic-btn" data-area="routing">🌐 underlay/routing</button>
        <button class="topic-btn" data-area="natmap">🔁 natmap</button>
        <button class="topic-btn" data-area="dhcplease">📡 dhcp pools</button>
        <button class="topic-btn" data-area="dnsrec">📖 dns & records</button>
        <button class="topic-btn" data-area="webpresence">🖥️ web presence</button>
        <button class="topic-btn" data-area="orchestra">🐳 containers/orch</button>
    </div>

    <div class="entries-grid" id="entriesGrid"></div>

    <!-- теория 2: про GRE/туннели -->
    <div class="theory-card" style="margin-top: 2rem;">
        <h3>🧠 Заметка: выбор между GRE и VxLAN</h3>
        <p>В большинстве случаев для связывания двух офисов через маршрутизаторы достаточно GRE+OSPF. GRE даёт простой point-to-point туннель, а OSPF динамически учит маршруты. Если нужна изоляция клиентов — можно посмотреть в сторону VRF, но для типовой задачи GRE — самый прозрачный вариант.</p>
    </div>

    <footer>
        инфраструктурный блокнот / конфигурации проверены на оборудовании и виртуальных машинах
    </footer>
</div>

<script>
    // ==========  ДАННЫЕ ПОЛНОСТЬЮ ИЗ ТВОЕЙ МЕТОДИЧКИ, НО С ДРУГИМИ КАТЕГОРИЯМИ  ==========
    const notes = [
        // sysbase (hostname + форвардинг)
        { area: "sysbase", title: "Смена идентификатора хоста", command: "hostnamectl set-hostname <name>", desc: "универсальный метод на systemd", example: "hostnamectl hostname hq-rtr && exec bash" },
        { area: "sysbase", title: "На роутерах Eltex", command: "hostname RTR_NAME", desc: "в конфигурационном режиме", example: "configure\nhostname HQ-RTR\nwrite" },
        { area: "sysbase", title: "IP forwarding (ядро)", command: "net.ipv4.ip_forward=1", desc: "разрешить маршрутизацию", example: "echo 1 > /proc/sys/net/ipv4/ip_forward\nsysctl -p" },
        
        // routing (GRE + OSPF)
        { area: "routing", title: "GRE туннель на HQ-RTR", command: "interface tunnel.0", desc: "туннель между HQ и BR", example: "ip address 10.10.10.1/24\nip tunnel 172.1.1.2 172.2.2.2 mode gre" },
        { area: "routing", title: "OSPF на HQ", command: "router ospf 1", desc: "анонс LAN и туннеля", example: "network 192.168.10.0/24 area 0\nnetwork 10.10.10.0/24 area 0" },
        { area: "routing", title: "OSPF на BR-RTR", command: "router ospf 1 (id 2.2.2.2)", desc: "backbone + пассивный интерфейс", example: "network 192.168.20.0/24 area 0\npassive-interface toLAN" },
        
        // natmap (masquerade + static)
        { area: "natmap", title: "MASQUERADE для выхода в интернет", command: "iptables -t nat -A POSTROUTING -o ens19 -j MASQUERADE", desc: "общий NAT", example: "iptables-save > /etc/sysconfig/iptables\nsystemctl enable --now iptables" },
        { area: "natmap", title: "Статический NAT (проброс портов)", command: "ip nat source static tcp", desc: "публикация web и uptime-kuma", example: "ip nat source static tcp 192.168.20.2 80 172.2.2.2 80\nip nat source static tcp 192.168.20.1 3001 172.2.2.2 3001" },
        { area: "natmap", title: "NAT inside/outside на интерфейсах", command: "ip nat inside / outside", desc: "привязка зон", example: "interface toLAN → ip nat inside\ninterface toISP → ip nat outside" },
        
        // dhcplease
        { area: "dhcplease", title: "DHCP-пул для LAN", command: "dhcp-server 1", desc: "выдача адресов клиентам", example: "dns 192.168.10.2\ngateway 192.168.10.1\ndomain-name ssa.lan\npool CLI 192.168.10.10-192.168.10.15" },
        { area: "dhcplease", title: "Клиентские настройки (ручные)", command: "options / ipv4address / resolv.conf", desc: "если DHCP не используется", example: "rm /etc/net/ifaces/ens19/ipv4address\noptions: dhcp and dhcp4" },
        
        // dnsrec
        { area: "dnsrec", title: "Мастер-зона ssa.lan (Bind)", command: "zone ssa.lan { type master; };", desc: "прямая зона", example: "hq-rtr IN A 192.168.10.1\nhq-srv IN A 192.168.10.2\nbr-srv IN A 192.168.20.2" },
        { area: "dnsrec", title: "Реверс 168.192.in-addr.arpa", command: "PTR записи", desc: "обратное разрешение", example: "1.10 IN PTR hq-rtr.ssa.lan.\n2.10 IN PTR hq-srv.ssa.lan.\n2.20 IN PTR br-srv.ssa.lan." },
        { area: "dnsrec", title: "Bind options (любой)", command: "listen-on { any; }; allow-query { any; }", desc: "доступ для всех клиентов", example: "chown root:named /etc/bind/zone/master/*\nsystemctl enable --now bind" },
        { area: "dnsrec", title: "Проверка DNS", command: "nslookup hq-srv.ssa.lan", desc: "должен вернуть 192.168.10.2", example: "dig @192.168.10.2 hq-srv.ssa.lan +short" },
        
        // webpresence
        { area: "webpresence", title: "nginx default host", command: "listen 80; server_name 127.0.0.1;", desc: "базовый виртуалхост", example: "root /var/www/html;\nindex index.html;" },
        { area: "webpresence", title: "Создание index страницы", command: "echo 'текст' > /var/www/html/index.html", desc: "заглушка филиала", example: "echo 'DOBRO POJALOVAT V FILIAL! EKZAMEN SDAET FIO' > /var/www/html/index.html" },
        { area: "webpresence", title: "Активация сайта", command: "ln -s sites-available.d/default.conf sites-enable.d/", desc: "включение конфига", example: "rm /etc/nginx/sites-enable.d/example.conf\nsystemctl restart nginx" },
        
        // orchestra (docker)
        { area: "orchestra", title: "docker-compose (uptime-kuma)", command: "services: uptime-kuma:", desc: "мониторинг", example: "image: louislam/uptime-kuma:1\nports: '3001:3001'\nvolumes: kuma-data:/app/data" },
        { area: "orchestra", title: "Запуск стека", command: "docker compose up -d", desc: "фоновая работа", example: "cd /opt/uptime-kuma\ndocker compose ps\ndocker compose logs -f" },
        { area: "orchestra", title: "Доступ к мониторингу", command: "http://192.168.20.2:3001", desc: "web-ui uptime-kuma", example: "добавить мониторинг HQ-SRV (192.168.10.2) и внешний пинг 8.8.8.8" }
    ];

    let currentArea = "all";
    let currentSearch = "";

    function renderEntries() {
        const grid = document.getElementById("entriesGrid");
        const filtered = notes.filter(item => {
            const areaMatch = currentArea === "all" || item.area === currentArea;
            const searchMatch = currentSearch === "" || 
                item.title.toLowerCase().includes(currentSearch) ||
                item.command.toLowerCase().includes(currentSearch) ||
                item.desc.toLowerCase().includes(currentSearch) ||
                item.example.toLowerCase().includes(currentSearch);
            return areaMatch && searchMatch;
        });

        if(filtered.length === 0) {
            grid.innerHTML = `<div style="grid-column:1/-1; text-align:center; padding:2rem;">⚡ ничего не найдено — возможно, стоит поискать по-другому</div>`;
            return;
        }

        grid.innerHTML = filtered.map(entry => `
            <div class="entry">
                <div class="entry-badge">${entry.area}</div>
                <div class="entry-title">${entry.title}</div>
                <div class="code-snip">$ ${entry.command}</div>
                <div class="desc-text">📌 ${entry.desc}</div>
                <div class="example-block">📋 ${entry.example}</div>
            </div>
        `).join("");
    }

    // фильтры
    document.querySelectorAll(".topic-btn").forEach(btn => {
        btn.addEventListener("click", () => {
            document.querySelectorAll(".topic-btn").forEach(b => b.classList.remove("active"));
            btn.classList.add("active");
            currentArea = btn.getAttribute("data-area");
            renderEntries();
        });
    });

    // поиск
    const searchBox = document.getElementById("searchInput");
    searchBox.addEventListener("input", (e) => {
        currentSearch = e.target.value.toLowerCase();
        renderEntries();
    });

    renderEntries();
</script>
</body>
</html>
